# harbor-tasks — internal endpoints (TEMPLATE)
# ---
# Copy to configs/local.env (gitignored) and fill in your real values. This PUBLIC
# repo intentionally contains NO internal topology — these values are injected:
#   - into the rich image at BUILD time   → environments/agent-rich/build.sh
#   - into the harbor process at RUN time → sourced by tools/run_track_a.sh,
#     tools/run_tau3.sh; read by hooks/wipe_memory_state.py & tools/agent_status.py
#
# `source configs/local.env` (or let the run scripts do it) before building/running.

# --- Memory services (shared backends; baked into harbor-agents-rich) ---------
HINDSIGHT_URL=http://<memory-host>:8888     # hindsight MCP (openclaw + hermes)
HONCHO_URL=http://<memory-host>:8000        # honcho (hermes memory provider)
RECALL_URL=http://<memory-host>:8408        # recall/Graphiti MCP (agent_status health)

# --- Memory-wipe hook (resets eval namespaces between trials) ------------------
<memory-host>_SSH=<user>@<memory-host>              # ssh target for recall-neo4j container exec

# --- Infisical (self-hosted) — secret injection for sweeps --------------------
INFISICAL_SITE_URL=http://<infisical-host>:8380
INFISICAL_PROJECT_ID=<shared-project-id>    # project holding OPENROUTER_API_KEY at /proxy/
