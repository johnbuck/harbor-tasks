{
  "agents": {
    "defaults": {
      "workspace": ".",
      "thinkingDefault": "high",
      "skipBootstrap": true
    }
  },
  "gateway": { "mode": "local" },

  "models": {
    "providers": {
      "xrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "${OPENROUTER_API_KEY}",
        "params": {
          "provider": { "data_collection": "deny", "only": ["novita"], "allow_fallbacks": false, "require_parameters": true }
        },
        "models": [
          {
            "id": "deepseek/deepseek-v4-pro",
            "name": "deepseek/deepseek-v4-pro",
            "reasoning": true,
            "compat": {
              "supportedReasoningEfforts": ["low", "medium", "high", "xhigh"]
            }
          }
        ]
      }
    }
  },

  "browser": {
    "enabled": true,
    "cdpUrl": "http://internal-host:9222"
  },

  "mcp": {
    "servers": {
      "hindsight": {
        "transport": "streamable-http",
        "url": "http://internal-host:8888/mcp/eval-openclaw/"
      }
    }
  },

  "tools": { "deny": ["message"] }
}
