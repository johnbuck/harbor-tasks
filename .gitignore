# Local secrets — never commit. Use `infisical run` to inject at runtime.
.env
.env.*
!.env.template

# Internal endpoints (memory hosts, Infisical coords) — kept OUT of this PUBLIC
# repo. Real values live here; commit only configs/local.env.example.
configs/local.env

# Internal memory-stack deployment mirror (docker-compose + recall config +
# wrapper notes). Contains load-bearing internal topology (host paths, the
# memory-host docker network); the canonical copy lives on the memory host.
# Kept local on the run host, OUT of this PUBLIC repo.
infra/

# Harbor job outputs (kept local; opt-in upload to Harbor Hub if needed)
jobs/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# Editors
.vscode/
.idea/
*.swp
.DS_Store

# Claude Code local session state — machine/user-specific (permission allowlists
# with local mount paths, transient locks); never commit to this public repo. A
# shared .claude/settings.json (no `.local`) can still be committed if ever wanted.
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Static generated dashboards are COMMITTED (so the suite is human-reviewable
# straight from the repo). Regenerate before committing task/spec changes:
# `python3 tools/task_catalog.py` / `python3 tools/roadmap.py`.
#
# EXCEPTION: agent-status.html is a LIVE-infra artifact — its generator embeds
# real memory-service URLs (memory host) + container config on every regen, so a
# committed copy always leaks internal topology. Kept local-only; regenerate to
# view live health: `python3 tools/agent_status.py`.
agent-status.html
