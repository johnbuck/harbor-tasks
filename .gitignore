# Local secrets — never commit. Use `infisical run` to inject at runtime.
.env
.env.*
!.env.template

# Internal endpoints (memory hosts, Infisical coords) — kept OUT of this PUBLIC
# repo. Real values live here; commit only configs/local.env.example.
configs/local.env

# Harbor job outputs (kept local; opt-in upload to Harbor Hub if needed)
jobs/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# Editors
.vscode/
.idea/
*.swp
.DS_Store

# Generated dashboards are COMMITTED (so the suite is human-reviewable straight
# from the repo, the whole point of the catalog). Regenerate before committing
# task changes: `python3 tools/task_catalog.py` / `python3 tools/agent_status.py`.
